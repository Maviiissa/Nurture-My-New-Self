    function todayStr() {
      return new Date().toISOString().slice(0, 10);
    }

    function toDate(s) {
      return new Date(s + "T00:00:00");
    }

    function diffDays(a, b) {
      const ms = 24 * 60 * 60 * 1000;
      return Math.floor((b - a) / ms);
    }

    function getProgramProgressInfo() {
      const start = toDate(state.startDate);
      const today = toDate(todayStr());
      let dayCount = diffDays(start, today) + 1;
      if (dayCount < 1) dayCount = 1;
      const totalDays = 10 * 30;
      const approxMonth = Math.min(10, Math.max(1, Math.ceil(dayCount / 30)));
      const approxWeek = Math.ceil(((dayCount - 1) % 30 + 1) / 7);
      return { dayCount, approxMonth, approxWeek, totalDays };
    }

    function getCurrentMonthPlan() {
      const info = getProgramProgressInfo();
      return monthPlans[info.approxMonth - 1];
    }

    function getEntriesArray() {
      return Object.entries(state.dailyEntries)
        .map(([date, data]) => ({ date, ...data }))
        .sort((a, b) => b.date.localeCompare(a.date));
    }

    function getWeeklyReviewsArray() {
      return Object.entries(state.weeklyReviews)
        .map(([date, data]) => ({ date, ...data }))
        .sort((a, b) => b.date.localeCompare(a.date));
    }

    function getLastNDates(n) {
      const out = [];
      const d = new Date();
      for (let i = 0; i < n; i++) {
        const t = new Date(d);
        t.setDate(d.getDate() - i);
        out.push(t.toISOString().slice(0, 10));
      }
      return out.reverse();
    }

    function sum(arr, key) {
      return arr.reduce((acc, x) => acc + (Number(x[key]) || 0), 0);
    }

    function avg(arr, key) {
      if (!arr.length) return 0;
      return sum(arr, key) / arr.length;
    }

    function clamp(n, min, max) {
      return Math.max(min, Math.min(max, n));
    }

    function percent(current, target) {
      if (!target || target <= 0) return 0;
      return clamp((current / target) * 100, 0, 100);
    }

    function getMonthDateRangeForCurrentProgramMonth() {
      const info = getProgramProgressInfo();
      const start = toDate(state.startDate);
      const monthStart = new Date(start);
      monthStart.setDate(start.getDate() + (info.approxMonth - 1) * 30);
      const monthEnd = new Date(monthStart);
      monthEnd.setDate(monthStart.getDate() + 29);

      return {
        start: monthStart.toISOString().slice(0, 10),
        end: monthEnd.toISOString().slice(0, 10)
      };
    }

    function getEntriesInRange(startDate, endDate) {
      return getEntriesArray().filter(e => e.date >= startDate && e.date <= endDate);
    }

    function renderOverview() {
      const info = getProgramProgressInfo();
      const plan = monthPlans[info.approxMonth - 1];
      ui.selectedMonthIndex = info.approxMonth - 1;

      els.currentMonthPill.textContent = `第${plan.month}个月｜${plan.stage}`;
      els.currentWeekPill.textContent = `第${info.approxWeek}周`;
      els.dayCountPill.textContent = `第${info.dayCount}天`;
      els.currentThemeText.textContent = `${plan.theme} 本月口号：${plan.motto}`;

      els.currentMonthWarnings.innerHTML = "";
      plan.warnings.forEach(w => {
        const li = document.createElement("li");
        li.textContent = w;
        els.currentMonthWarnings.appendChild(li);
      });

      const range = getMonthDateRangeForCurrentProgramMonth();
      const monthEntries = getEntriesInRange(range.start, range.end);

      const taskDays = monthEntries.filter(e => e.didKeyTask).length;
      const exerciseDays = monthEntries.filter(e => (Number(e.exerciseMinutes) || 0) > 0).length;
      const logDays = monthEntries.length;

      const monthTargets = {
        taskDays: 20,
        exerciseDays: 16,
        logDays: 20
      };

      els.progressTaskLabel.textContent = `${taskDays} / ${monthTargets.taskDays}`;
      els.progressExerciseLabel.textContent = `${exerciseDays} / ${monthTargets.exerciseDays}`;
      els.progressLogLabel.textContent = `${logDays} / ${monthTargets.logDays}`;

      els.progressTaskBar.style.width = `${percent(taskDays, monthTargets.taskDays)}%`;
      els.progressExerciseBar.style.width = `${percent(exerciseDays, monthTargets.exerciseDays)}%`;
      els.progressLogBar.style.width = `${percent(logDays, monthTargets.logDays)}%`;

      // 7-day KPIs
      const last7Dates = getLastNDates(7);
      const last7 = last7Dates
        .map(d => ({ date: d, ...(state.dailyEntries[d] || {}) }))
        .filter(e => Object.keys(e).length > 1);

      const researchMinutes = sum(last7, "researchMinutes");
      const exerciseDays7 = last7.filter(e => (Number(e.exerciseMinutes) || 0) > 0).length;
      const screenMinutes = sum(last7, "screenMinutes");
      const sleepAvg = avg(last7.filter(e => e.sleepHours !== undefined), "sleepHours");
      const energyAvg = avg(last7.filter(e => e.energyScore !== undefined), "energyScore");

      const highPressure = last7.filter(e => e.highPressureDay);
      const highPressureExecuted = highPressure.filter(e => e.didKeyTask).length;
      const highPressureRate = highPressure.length ? (highPressureExecuted / highPressure.length) * 100 : 0;

      els.kpiResearch.textContent = `${(researchMinutes / 60).toFixed(1)}h`;
      els.kpiExercise.textContent = `${exerciseDays7}次`;
      els.kpiScreen.textContent = `${(screenMinutes / 60).toFixed(1)}h`;
      els.kpiSleep.textContent = `${sleepAvg ? sleepAvg.toFixed(1) : 0}h`;
      els.kpiEnergy.textContent = `${energyAvg ? energyAvg.toFixed(1) : 0}`;
      els.kpiHighPressure.textContent = `${Math.round(highPressureRate)}%`;

      // assessment
      let notes = [];
      if (researchMinutes >= 175) notes.push("科研推进有基本盘");
      else notes.push("科研推进偏少，优先保住25分钟最小块");

      if (exerciseDays7 >= 4) notes.push("运动频率不错，继续稳住");
      else if (exerciseDays7 > 0) notes.push("运动在启动中，先追求不断线");
      else notes.push("本周运动为0，先做15分钟版本");

      if (screenMinutes > researchMinutes) notes.push("屏幕逃避仍高于科研，重点做消息窗口化");
      else notes.push("科研时间开始压过屏幕逃避，这是好信号");

      els.systemAssessment.textContent = `系统判读：${notes.join("；")}。记住，你在做系统发育，不是情绪表演。`;
    }

