    }

    function renderHistory() {
      const arr = getEntriesArray();
      if (!arr.length) {
        els.historyList.innerHTML = `<div class="entry small muted">还没有每日记录</div>`;
        return;
      }

      els.historyList.innerHTML = arr.slice(0, 30).map(e => {
        const minFormula = [
          (e.didKeyTask || (Number(e.researchMinutes) || 0) >= 25) ? "关键任务" : null,
          (Number(e.exerciseMinutes) || 0) >= 15 ? "运动" : null,
          (Number(e.recoveryMinutes) || 0) > 0 ? "恢复" : null
        ].filter(Boolean);

        return `
          <div class="entry">
            <div class="entry-header">
              <span>${e.date}</span>
              <span class="small muted">${minFormula.length ? "已供养：" + minFormula.join("、") : "波动日"}</span>
            </div>
            <div class="small">
              科研 ${(Number(e.researchMinutes) || 0)} 分钟 ｜ 工作 ${(Number(e.workMinutes) || 0)} 分钟 ｜ 运动 ${(Number(e.exerciseMinutes) || 0)} 分钟 ｜ 屏幕 ${(Number(e.screenMinutes) || 0)} 分钟
            </div>
            <div class="small muted" style="margin-top:4px;">
              睡眠 ${(Number(e.sleepHours) || 0)} 小时 ｜ 精力 ${(Number(e.energyScore) || 0)} ｜ 劫持 ${(Number(e.messageHijacks) || 0)} 次
            </div>
            ${e.dailyNote ? `<div class="small" style="margin-top:6px;"><strong>胎动：</strong>${escapeHtml(e.dailyNote)}</div>` : ""}
          </div>
        `;
      }).join("");
    }

    function renderIdentity() {
      els.identityStatement.textContent = state.identityStatement;
    }

    function renderAll() {
      renderIdentity();
      renderOverview();
      renderDailyHintsPreview();
      renderWeeklySnapshot();
      renderWeeklyHistory();
      renderMonthsList();
      renderHistory();
    }

    function escapeHtml(str) {
      return String(str)
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#039;");
    }

    function switchTab(tabName) {
      document.querySelectorAll(".tab-btn").forEach(btn => {
        btn.classList.toggle("active", btn.dataset.tab === tabName);
      });
      document.querySelectorAll(".tab-panel").forEach(panel => {
        panel.classList.add("hidden");
      });
      document.getElementById(`tab-${tabName}`).classList.remove("hidden");
    }

    // events
    document.querySelectorAll(".tab-btn").forEach(btn => {
      btn.addEventListener("click", () => switchTab(btn.dataset.tab));
    });

    els.editIdentityBtn.addEventListener("click", () => {
      const next = prompt("修改你的身份句子（会显示在首页）", state.identityStatement);
      if (next && next.trim()) {
        state.identityStatement = next.trim();
        saveData();
      }
    });

    els.exportBtn.addEventListener("click", () => {
      const blob = new Blob([JSON.stringify(state, null, 2)], { type: "application/json" });
      const a = document.createElement("a");
      a.href = URL.createObjectURL(blob);
      a.download = `rebirth10-backup-${todayStr()}.json`;
      a.click();
      URL.revokeObjectURL(a.href);
    });

    els.importBtn.addEventListener("click", () => els.importFile.click());

    els.importFile.addEventListener("change", async (e) => {
      const file = e.target.files?.[0];
      if (!file) return;
      try {
        const text = await file.text();
        const data = JSON.parse(text);
        if (!data.dailyEntries || !data.weeklyReviews) {
          alert("导入失败：文件格式不对");
          return;
        }
        state = {
          ...defaultData(),
          ...data,
          dailyEntries: data.dailyEntries || {},
          weeklyReviews: data.weeklyReviews || {}
        };
        localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
        renderAll();
        setDailyForm(todayStr());
        setWeeklyForm(todayStr());
        alert("导入成功");
      } catch (err) {
        console.error(err);
        alert("导入失败：无法解析 JSON");
      } finally {
        e.target.value = "";
      }
    });

    [
      els.researchMinutes, els.workMinutes, els.exerciseMinutes, els.screenMinutes,
      els.sleepHours, els.recoveryMinutes, els.energyScore, els.messageHijacks,
      els.didKeyTask, els.highPressureDay, els.didMinActionInAnxiety, els.dailyNote
    ].forEach(el => {
      el.addEventListener("input", renderDailyHintsPreview);
      el.addEventListener("change", renderDailyHintsPreview);
    });

    els.saveEntryBtn.addEventListener("click", () => {
      const { date, data } = readDailyForm();
      state.dailyEntries[date] = data;
      saveData();
      alert(`已保存 ${date} 的记录`);
    });

    els.loadTodayBtn.addEventListener("click", () => {
      const d = els.entryDate.value || todayStr();
      setDailyForm(d);
    });

    els.deleteTodayBtn.addEventListener("click", () => {
      const d = els.entryDate.value || todayStr();
      if (!state.dailyEntries[d]) {
        alert("这一天没有记录");
        return;
      }
      if (confirm(`确认删除 ${d} 的记录吗？`)) {
        delete state.dailyEntries[d];
        saveData();
        setDailyForm(d);
      }
    });

    els.entryDate.addEventListener("change", () => setDailyForm(els.entryDate.value));

    els.saveWeeklyBtn.addEventListener("click", () => {
      const d = els.weeklyDate.value || todayStr();
      state.weeklyReviews[d] = {
        weeklyWins: els.weeklyWins.value.trim(),
        weeklyHijacks: els.weeklyHijacks.value.trim(),
        weeklyWorks: els.weeklyWorks.value.trim(),
        weeklyAdjustments: els.weeklyAdjustments.value.trim(),
        updatedAt: new Date().toISOString()
      };
      saveData();
      alert(`已保存 ${d} 的周复盘`);
    });

    els.loadWeeklyBtn.addEventListener("click", () => {
      const d = els.weeklyDate.value || todayStr();
      setWeeklyForm(d);
    });

    els.weeklyDate.addEventListener("change", () => setWeeklyForm(els.weeklyDate.value));

    els.prevMonthBtn.addEventListener("click", () => {
      ui.selectedMonthIndex = Math.max(0, ui.selectedMonthIndex - 1);
      renderMonthsList();
    });

    els.nextMonthBtn.addEventListener("click", () => {
      ui.selectedMonthIndex = Math.min(monthPlans.length - 1, ui.selectedMonthIndex + 1);
      renderMonthsList();
    });

    // init
    if (!state.startDate) state.startDate = todayStr();
    els.entryDate.value = todayStr();
    els.weeklyDate.value = todayStr();

    setDailyForm(todayStr());
    setWeeklyForm(todayStr());
    renderAll();
  </script>
</body>
</html>
